{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/index",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(tabs)/index",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/(tabs)/explore",
      "destination": "/explore",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/explore",
      "destination": "/explore.html"
    },
    {
      "source": "/game",
      "destination": "/game.html"
    },
    {
      "source": "/tutorial",
      "destination": "/tutorial.html"
    }
  ]
}
